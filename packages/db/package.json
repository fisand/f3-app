{
  "name": "db",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "clean": "rm -rf dist",
    "db:deploy": "vp exec prisma migrate deploy",
    "db:dev": "vp exec prisma migrate dev",
    "db:dev:create": "vp exec prisma migrate dev --create-only",
    "db:push": "vp exec prisma db push",
    "dev": "vp pack --w --no-clean",
    "format": "vp exec prisma format",
    "generate": "vp exec prisma generate",
    "lint": "vp lint src",
    "postinstall": "vp run generate && vp run build",
    "studio": "vp exec prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "prisma": "^6.19.3"
  },
  "packageManager": "pnpm@10.5.2"
}
