{
  "name": "drizzle",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "vp pack",
    "clean": "rm -rf dist",
    "dev": "vp pack --w --no-clean",
    "generate": "vp exec drizzle-kit generate",
    "kit-pull": "vp exec drizzle-kit pull",
    "lint": "vp lint src",
    "migrate": "vp exec drizzle-kit migrate",
    "postinstall": "vp run build",
    "push": "vp exec drizzle-kit push"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10"
  },
  "packageManager": "pnpm@10.5.2"
}
